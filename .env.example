# ─── Base de données PostgreSQL ───────────────────────────────────────────────
# Utilisés par docker-compose pour créer la base et construire DATABASE_URL
POSTGRES_DB=brawlally
POSTGRES_USER=brawlally
POSTGRES_PASSWORD=change_me_please

# ─── Discord OAuth2 ───────────────────────────────────────────────────────────
# Créer une app sur https://discord.com/developers/applications
# Ajouter le redirect URI : https://TON_DOMAINE/api/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── API Meonix (données Brawl Stars) ─────────────────────────────────────────
DISCORD_API_KEY=

# ─── Session Express ──────────────────────────────────────────────────────────
# Chaîne aléatoire longue et secrète (ex: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_long_random_string

# ─── Serveur ──────────────────────────────────────────────────────────────────
# Port exposé sur la machine hôte (le container écoute toujours sur 8080)
PORT=8080

# URL publique de l'application (schéma + domaine, sans slash final)
# Utilisée pour construire la redirect URI Discord OAuth2
# Obligatoire si tu n'es pas derrière un proxy qui forward X-Forwarded-Proto
# Exemples :
#   BASE_URL=https://mondomaine.com
#   BASE_URL=http://localhost:8080
BASE_URL=https://mondomaine.com

# Force le flag Secure sur le cookie de session
# true  → cookie Secure (HTTPS requis) — recommandé en production
# false → cookie non-Secure (HTTP ok) — utile en local sans HTTPS
# non défini → automatique (true si NODE_ENV=production)
COOKIE_SECURE=true

# Si ton reverse proxy ne forwarde pas X-Forwarded-Proto (vérifie avec /api/auth/debug)
# Mettre à true force Express à traiter toutes les requêtes comme HTTPS
# Nécessaire pour que le cookie de session soit envoyé par le navigateur
FORCE_HTTPS=true
