# ─── Base de données PostgreSQL ───────────────────────────────────────────────
# Utilisés par docker-compose pour créer la base et construire DATABASE_URL
POSTGRES_DB=brawlally
POSTGRES_USER=brawlally
POSTGRES_PASSWORD=change_me_please

# ─── Discord OAuth2 ───────────────────────────────────────────────────────────
# Créer une app sur https://discord.com/developers/applications
# Ajouter le redirect URI : https://TON_DOMAINE/api/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── API Meonix (données Brawl Stars) ─────────────────────────────────────────
DISCORD_API_KEY=

# ─── Session Express ──────────────────────────────────────────────────────────
# Chaîne aléatoire longue et secrète (ex: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_long_random_string

# ─── Serveur ──────────────────────────────────────────────────────────────────
# Port exposé sur la machine hôte (le container écoute toujours sur 8080)
PORT=8080
